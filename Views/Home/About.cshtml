    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@

@{
    ViewData["Title"] = "About";
}

<div class="container page-container">
    <!-- Intro Section -->
    <section class="section">
        <div class="row align-items-center g-4">
            <div class="col-lg-7">
                <span class="badge rounded-pill mb-3" style="background-color:#2EC4B6; color:#ffffff;">
                    About BetFlow Systems
                </span>

                <h1 class="display-6 fw-bold mb-3">
                    A Specialized Dashboard for Betting Account Data
                </h1>

                <p class="lead text-muted">
                    BetFlow Systems is designed to simplify how betting account information is viewed,
                    maintained, and controlled. The platform provides a clean administrative interface
                    for interacting with database tables while supporting accurate and secure record management.
                </p>

                <p class="text-muted">
                    Instead of relying on direct database access, BetFlow Systems presents important
                    data in a structured dashboard environment. This allows users to perform controlled
                    operations while reducing the risk of inconsistent, incomplete, or invalid information.
                </p>
            </div>

            <div class="col-lg-5">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-diagram-3 me-2"></i>
                        System Purpose
                    </div>
                    <div class="card-body">
                        <p class="text-muted">
                            BetFlow Systems supports the management of betting account database records
                            through visibility, validation, and structured CRUD functionality.
                        </p>

                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                View database table records
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Manage betting account information
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Apply CRUD operations safely
                            </li>
                            <li>
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Maintain data integrity with constraints
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Core Capabilities -->
    <section class="section">
        <div class="text-center mb-4">
            <h2>Core Capabilities</h2>
            <p class="text-muted">
                Built around the practical needs of database-driven betting account management.
            </p>
        </div>

        <div class="row g-4">
            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <i class="bi bi-speedometer2 fs-2 mb-3" style="color:#155a5b;"></i>
                        <h5>Dashboard Access</h5>
                        <p class="text-muted mb-0">
                            Centralized access to database information through a clean and easy-to-use interface.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <i class="bi bi-grid-3x3-gap fs-2 mb-3" style="color:#155a5b;"></i>
                        <h5>Table Views</h5>
                        <p class="text-muted mb-0">
                            Display key records in organized tables that are easier to read and manage.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <i class="bi bi-tools fs-2 mb-3" style="color:#155a5b;"></i>
                        <h5>CRUD Operations</h5>
                        <p class="text-muted mb-0">
                            Create, update, view, and delete records through structured user actions.
                        </p>
                    </div>
                </div>
            </div>

            <div class="col-md-6 col-lg-3">
                <div class="card h-100">
                    <div class="card-body p-4">
                        <i class="bi bi-lock fs-2 mb-3" style="color:#155a5b;"></i>
                        <h5>Integrity Checks</h5>
                        <p class="text-muted mb-0">
                            Support cleaner data through database constraints and application-level validation.
                        </p>
                    </div>
                </div>
            </div>
        </div>
    </section>

    <!-- Integrity Section -->
    <section class="section">
        <div class="card">
            <div class="card-body p-4 p-md-5">
                <div class="row g-4 align-items-center">
                    <div class="col-lg-6">
                        <h2>Designed Around Data Integrity</h2>
                        <p class="text-muted">
                            In betting account management, reliable data is essential. BetFlow Systems
                            supports integrity by combining rules at the database level with checks in
                            the application code.
                        </p>

                        <p class="text-muted mb-0">
                            This layered approach helps prevent invalid records, protects relationships
                            between tables, and improves confidence in the accuracy of stored information.
                        </p>
                    </div>

                    <div class="col-lg-6">
                        <div class="row g-3">
                            <div class="col-sm-6">
                                <div class="p-3 rounded bg-light h-100">
                                    <i class="bi bi-database-lock fs-3 mb-2" style="color:#155a5b;"></i>
                                    <h5>DB-Level Constraints</h5>
                                    <p class="text-muted mb-0">
                                        Enforce rules directly in the database structure.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="p-3 rounded bg-light h-100">
                                    <i class="bi bi-code-slash fs-3 mb-2" style="color:#155a5b;"></i>
                                    <h5>Code-Level Validation</h5>
                                    <p class="text-muted mb-0">
                                        Validate user actions before records are saved.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="p-3 rounded bg-light h-100">
                                    <i class="bi bi-arrow-repeat fs-3 mb-2" style="color:#155a5b;"></i>
                                    <h5>Consistent Workflows</h5>
                                    <p class="text-muted mb-0">
                                        Keep data handling predictable and controlled.
                                    </p>
                                </div>
                            </div>

                            <div class="col-sm-6">
                                <div class="p-3 rounded bg-light h-100">
                                    <i class="bi bi-clipboard-check fs-3 mb-2" style="color:#155a5b;"></i>
                                    <h5>Cleaner Records</h5>
                                    <p class="text-muted mb-0">
                                        Reduce mistakes across account-related tables.
                                    </p>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>
