@*
    For more information on enabling MVC for empty projects, visit https://go.microsoft.com/fwlink/?LinkID=397860
*@
@{
}


@{
    ViewData["Title"] = "Contact";
}

<div class="container page-container">
    <!-- Header -->
    <section class="section">
        <div class="text-center">
            <span class="badge rounded-pill mb-3" style="background-color:#2EC4B6; color:#ffffff;">
                Contact BetFlow Systems
            </span>

            <h1 class="display-6 fw-bold">
                Get in Touch
            </h1>

            <p class="lead text-muted mx-auto" style="max-width: 750px;">
                Have questions about BetFlow Systems or need more information about the dashboard?
                Send us a message and we will get back to you.
            </p>
        </div>
    </section>

    <!-- Contact Content -->
    <section class="section">
        <div class="row g-4">
            <!-- Contact Form -->
            <div class="col-lg-7">
                <div class="card">
                    <div class="card-header">
                        <i class="bi bi-envelope-paper me-2"></i>
                        Send a Message
                    </div>

                    <div class="card-body p-4">
                        <form>
                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label for="fullName" class="form-label">Full Name</label>
                                    <input type="text"
                                           class="form-control"
                                           id="fullName"
                                           name="fullName"
                                           placeholder="Enter your full name" />
                                </div>

                                <div class="col-md-6">
                                    <label for="emailAddress" class="form-label">Email Address</label>
                                    <input type="email"
                                           class="form-control"
                                           id="emailAddress"
                                           name="emailAddress"
                                           placeholder="Enter your email address" />
                                </div>

                                <div class="col-12">
                                    <label for="subject" class="form-label">Subject</label>
                                    <input type="text"
                                           class="form-control"
                                           id="subject"
                                           name="subject"
                                           placeholder="What would you like to discuss?" />
                                </div>

                                <div class="col-12">
                                    <label for="message" class="form-label">Message</label>
                                    <textarea class="form-control"
                                              id="message"
                                              name="message"
                                              rows="6"
                                              placeholder="Write your message here..."></textarea>
                                </div>

                                <div class="col-12">
                                    <button type="submit" class="btn btn-primary">
                                        <i class="bi bi-send me-2"></i>
                                        Send Message
                                    </button>
                                </div>
                            </div>
                        </form>

                        <div class="alert alert-success mt-4 mb-0" role="alert">
                            <i class="bi bi-info-circle me-2"></i>
                            This form is currently prepared for frontend display. Backend handling can be added later.
                        </div>
                    </div>
                </div>
            </div>

            <!-- Contact Info -->
            <div class="col-lg-5">
                <div class="card mb-4">
                    <div class="card-header">
                        <i class="bi bi-building me-2"></i>
                        BetFlow Systems
                    </div>

                    <div class="card-body p-4">
                        <p class="text-muted">
                            BetFlow Systems provides a specialized dashboard for betting account database
                            management, offering table visibility, controlled CRUD operations, and layered
                            data integrity support.
                        </p>

                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-database fs-4 me-3" style="color:#155a5b;"></i>
                            <div>
                                <h5 class="mb-1">Database Management</h5>
                                <p class="text-muted mb-0">
                                    View and manage account-related records through a clean dashboard interface.
                                </p>
                            </div>
                        </div>

                        <div class="d-flex align-items-start mb-3">
                            <i class="bi bi-shield-check fs-4 me-3" style="color:#155a5b;"></i>
                            <div>
                                <h5 class="mb-1">Data Integrity</h5>
                                <p class="text-muted mb-0">
                                    Support accurate records using database constraints and validation logic.
                                </p>
                            </div>
                        </div>

                        <div class="d-flex align-items-start">
                            <i class="bi bi-ui-checks-grid fs-4 me-3" style="color:#155a5b;"></i>
                            <div>
                                <h5 class="mb-1">Admin-Friendly Interface</h5>
                                <p class="text-muted mb-0">
                                    Simplify database interactions without requiring direct database access.
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Quick Info Card -->
                <div class="card">
                    <div class="card-body p-4">
                        <h4 class="mb-3">Why Contact Us?</h4>

                        <ul class="list-unstyled mb-0">
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Learn more about the dashboard features
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Discuss database table management
                            </li>
                            <li class="mb-2">
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Ask about CRUD functionality
                            </li>
                            <li>
                                <i class="bi bi-check-circle-fill text-credit me-2"></i>
                                Explore validation and constraint support
                            </li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
    </section>
</div>