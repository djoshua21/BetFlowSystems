@model BetFlowSystems.Models.DTOs.Admin.UpdateAdminDto

@{
    ViewData["Title"] = "Edit Staff Account";
}

<div class="container page-container">
    <div class="row justify-content-center mb-5">
        <div class="col-md-8 col-lg-7">
            <div class="card">
                <div class="card-header bg-create-header">
                    <h4 class="mb-0">Edit Staff Account</h4>
                </div>

                <div class="card-body">
                    <form asp-controller="Admin" asp-action="Edit" method="post" asp-validation-summary="ModelOnly" class="alert alert-danger">

                        <input asp-for="AdminId" type="hidden" />

                        <div>
                        </div>

                        <h5 class="mb-3">Account Details</h5>

                        <div class="mb-3">
                            <label>Admin ID</label>
                            <div class="form-control">@Model.AdminId</div>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">Email Address</label>
                            <input asp-for="Email" class="form-control" placeholder="Enter email address" type="email" required />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="Role" class="form-label">Role</label>
                            <select asp-for="Role" class="form-select" required>
                                <option value="Clerk">Clerk</option>
                                <option value="Manager">Manager</option>
                                <option value="Admin">Admin</option>
                            </select>
                            <span asp-validation-for="Role" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label class="form-label">Account Status</label>

                            <div class="form-check">
                                <input asp-for="IsLocked" class="form-check-input" />
                                <label asp-for="IsLocked" class="form-check-label">
                                    Lock this account
                                </label>
                            </div>

                            <small class="text-muted">
                                If checked, this staff member will not be able to log in.
                            </small>
                        </div>

                        <hr />

                        <h5 class="mb-3">Change Password</h5>

                        <div class="alert alert-danger">
                            Leave the password fields blank if you do not want to change the password.
                        </div>

                        <div class="mb-3">
                            <label asp-for="NewPassword" class="form-label">New Password</label>
                            <input asp-for="NewPassword" type="password" class="form-control" placeholder="Enter new password" />
                            <span asp-validation-for="NewPassword" class="text-danger"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="ConfirmPassword" class="form-label">Confirm New Password</label>
                            <input asp-for="ConfirmPassword" type="password" class="form-control" placeholder="Confirm new password" />
                            <span asp-validation-for="ConfirmPassword" class="text-danger"> </span>
                        </div>

                        <div class="d-flex justify-content-between">
                            <a asp-controller="Admin" asp-action="Index" class="btn btn-secondary">Cancel</a>

                            <button type="submit" class="btn btn-primary">
                                Save Changes
                            </button>

                        </div>
                    </form>
                </div>
            </div>

            <div class="text-center mt-3">
                <small class="text-muted">
                    Password changes must follow your Identity password rules.
                </small>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}