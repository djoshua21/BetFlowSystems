@using BetFlowSystems
@using BetFlowSystems.Models
@using BetFlowSystems.Models.DTOs.Transaction
@using BetFlowSystems.Models.Helpers
@addTagHelper *, Microsoft.AspNetCore.Mvc.TagHelpers

@model PagedResult<DisplayTransactionDto>

@{
    ViewData["Title"] = "Transactions";
}

<div class="container section">

    <div class="d-flex justify-content-between align-items-center mb-3">
        <h2 class="mb-0 mr-3">Transactions</h2>


            
        <form class="form-inline w-75" asp-action="Index" asp-controller="Transaction" method="get">
            <input class="form-control mr-sm-2 w-75"
                   type="search"
                   value="@ViewBag.CurrentFilter"
                   placeholder="Bet or Transaction ID"
                   aria-label="Search"
                   name="search"
                   maxlength="50" />
            <div>
                <button class="btn btn-secondary my-2 my-sm-0 mx-1" type="submit">Search</button>
                <a asp-action="Index" class="btn btn-outline-secondary mx-1 my-xl-0 ">Clear</a>
            </div>
        </form>

    </div>


    <div class="card">
        <div class="card-body p-0">
            <table class="table mb-0">
                <thead>
                    <tr>
                        <th>Transaction ID</th>

                        <th>Bet ID/User Action</th>
                        <th>Acc ID</th>
                        <th>Amount</th>
                        <th>Transaction Type</th>

                        <th class="text-end">Transaction Date</th>
                    </tr>
                </thead>
                <tbody>
                    @if (Model == null || !Model.Items.Any())
                    {
                        <tr>
                            <td colspan="6" class="text-center p-4">
                                <div style="text-align:center">
                                    No Transactions found.
                                </div>
                            </td>
                        </tr>
                    }
                    else
                    {
                        foreach (var transaction in Model.Items)
                        {


                            <tr>
                                <td>@(transaction.TransactionID)</td>
                                @* <td>@(transaction.BetID)</td> *@

                                @if (transaction.BetID != null)
                                {
                                    <td>@(transaction.BetID)</td>
                                }
                                else
                                {
                                    if (transaction.TransactionType == DebitOrCredit.Debit)
                                    {
                                        <td>Withdrawal</td>
                                    }
                                    else
                                    {
                                        <td>Deposit</td>
                                    }

                                    
                                }

                                <td>@(transaction.AccountID)</td>
                                <td>@(transaction.Amount)</td>

                                <td>
                                    @if (transaction.TransactionType == DebitOrCredit.Credit)
                                    {
                                        <span class="badge badge-open p-2">
                                            @transaction.TransactionType.ToString()
                                        </span>
                                    }
                                    else if (transaction.TransactionType == DebitOrCredit.Debit)
                                    {
                                        <span class="badge badge-closed p-2">
                                            @transaction.TransactionType.ToString()
                                        </span>
                                    }
                                </td>

                                <td>@(transaction.TransactionDate.ToShortDateString())</td>

                                

                            </tr>
                        }
                    }
                </tbody>
            </table>

            <nav>
                <ul class="pagination justify-content-center">
                    @for (int i = 1; i <= Model!.TotalPages; i++)
                    {
                        if (i == Model.CurrentPage)
                        {
                            <li class="page-item active">
                                <span class="page-link ">@i</span>
                            </li>
                        }
                        else
                        {
                            <li class="page-item">
                                <a class="page-link" href="@Url.Action("Index", new { page = i })">@i</a>
                            </li>
                        }
                    }
                </ul>
            </nav>
        </div>
    </div>
</div>
