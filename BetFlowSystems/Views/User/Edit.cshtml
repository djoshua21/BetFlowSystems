@using BetFlowSystems.Models.DTOs.User

@model DisplayUserDto

@{
    ViewData["Title"] = "Edit User";
}

<div class="container page-container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card mt-4 mb-5">
                <div class="card-header d-flex justify-content-between align-items-center bg-warning">
                    <h3 class="mb-0">Edit User</h3>
                    <span class="badge @(Model != null && Model.IsActive ? "badge-open" : "badge-closed")">
                        @(Model != null && Model.IsActive ? "Active" : "Inactive")
                    </span>
                </div>

                <div class="card-body">
                    <form asp-action="Edit">
                        <div>

                            <input type="hidden" asp-for="UserID" />
                            <input type="hidden" asp-for="CreatedDate" />
                            <input type="hidden" asp-for="IdNumber" />

                            <div class="row g-3">
                                <div class="col-md-6">
                                    <label asp-for="UserID" class="form-label">User ID</label>
                                    <input asp-for="UserID" class="form-control" readonly />
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="IdNumber" class="form-label">ID Number</label>
                                    <input class="form-control"
                                           value="@Model!.IdNumber"
                                           readonly />

                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Name" class="form-label">Name</label>
                                    <input asp-for="Name" class="form-control" maxlength="50" />
                                    <span asp-validation-for="Name" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="Surname" class="form-label">Surname</label>
                                    <input asp-for="Surname" class="form-control" maxlength="50" />
                                    <span asp-validation-for="Surname" class="text-danger"></span>
                                </div>

                                <div class="col-12">
                                    <label asp-for="Address" class="form-label">Address</label>
                                    <textarea asp-for="Address" class="form-control" rows="1" maxlength="200"></textarea>
                                    <span asp-validation-for="Address" class="text-danger"></span>
                                </div>

                                <div class="col-md-6">
                                    <label asp-for="CreatedDate" class="form-label">Created Date</label>
                                    <input class="form-control" value="@Model.CreatedDate.ToString("dd MMM yyyy HH:mm")" readonly />
                                </div>

                                <div class="col-md-6 d-flex align-items-end">
                                    <div class="form-check mt-3">
                                        <input asp-for="IsActive" class="form-check-input" />
                                        <label asp-for="IsActive" class="form-check-label">
                                            Active User
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <hr class="my-4" />
                            <div class="d-flex justify-content-between">
                                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
                                <button type="submit" class="btn btn-primary">
                                    Save Changes
                                </button>
                            </div>

                            

                            
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}