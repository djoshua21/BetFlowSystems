@using BetFlowSystems.Models.DTOs.Simulation


@model SimulationDto

@{
    ViewData["Title"] = "User Simulation";
}

<div class="container page-container">

    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">

            <div class="card">

                <div class="card-header d-flex justify-content-between align-items-center bg-secondary text-white">
                    <h2>User Simulation Panel</h2>

                </div>


                <form asp-action="Execute" method="post" class="card-body">


                    <div>
                        <label>Account Number</label>
                        <input asp-for="AccountID" class="form-control" type="number" step="1" min="1" />
                    </div>

                    <div>
                        <label>Amount</label>
                        <input asp-for="Amount" class="form-control" type="number" step="0.50" min="1" />
                    </div>

                    <div>
                        <label>Select Action</label>
                        <select asp-for="ActionType" class="form-control" required>
                            <option value="">-- Choose Action --</option>
                            <option value="Deposit">Deposit</option>
                            <option value="Withdraw">Withdraw</option>
                            <option value="Zero">Zero Account</option>
                            <option value="RandomBet">Generate Random Bet</option>
                        </select>
                    </div>

                    <br />
                    <button type="submit" class="btn btn-primary">Run</button>

                </form>

                @if (!string.IsNullOrEmpty(Model.ResultMessage))
                {
                    <div class="alert alert-info mx-3">
                        @Model.ResultMessage
                    </div>
                }
            </div>
        </div>
    </div>
</div>
