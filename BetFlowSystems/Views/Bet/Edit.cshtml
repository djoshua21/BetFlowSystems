@using BetFlowSystems.Models.DTOs.Bet

@model DisplayBetDto;

@{
    ViewData["Title"] = "Bet Details";
}

<div class="container page-container">
    <div class="row justify-content-center">
        <div class="col-lg-8 col-md-10">
            <div class="card mt-4 mb-5">
                <div class="card-header d-flex justify-content-between align-items-center bg-success text-white">
                    <h3 class="mb-0">Edit Bet</h3>
                    <span class="badge bg-light text-dark">@Model.Result.ToString()</span>
                </div>

                <div class="card-body">

                    <form asp-action="Edit" class="mb-3">
                        <div class="row g-3">

                            <input type="hidden" asp-for="BetID" />
                            <input type="hidden" asp-for="AccountID" />
                            <input type="hidden" asp-for="BetTypeID" />
                            <input type="hidden" asp-for="BetAmount" />
                            <input type="hidden" asp-for="PossibleWinAmount" />
                            <input type="hidden" asp-for="BetDate" />
                            <input type="hidden" asp-for="LastUpdatedDate" />

                            <div class="col-md-6">
                                <label>Bet ID</label>
                                <div class="form-control bg-light">@Model.BetID</div>
                            </div>

                            <div class="col-md-6">
                                <label>Account ID</label>
                                <div class="form-control bg-light">@Model.AccountID</div>
                            </div>

                            <div class="col-md-6">
                                <label>Bet Type ID</label>
                                <div class="form-control bg-light">@Model.BetTypeID</div>
                            </div>

                            <div class="col-md-6">
                                <label asp-for="Result" class="form-label">Result Status</label>
                                <select asp-for="Result" class="form-control" asp-items="Html.GetEnumSelectList<BetStatus>()">
                                    <option value="">-- Select Status --</option>
                                </select>
                                <span asp-validation-for="Result" class="text-danger"></span>
                            </div>

                            <div class="col-md-6">
                                <label>Bet Amount</label>
                                <div class="form-control bg-light">@Model.BetAmount</div>
                            </div>


                            <div class="col-md-6">
                                <label>Win Amount (incl. stake)</label>
                                <div class="form-control bg-light">@Model.PossibleWinAmount</div>
                            </div>

                            <div class="col-md-6">
                                <label>Bet Date</label>
                                <div class="form-control bg-light">@Model.BetDate.ToShortDateString()</div>
                            </div>

                            <div class="col-md-6">
                                <label>Last Updated</label>
                                <div class="form-control bg-light">@Model.LastUpdatedDate.Date.ToShortDateString()</div>
                            </div>
                        </div>

                        <hr class="my-4" />

                        <div class="d-flex justify-content-between">
                            @{
                                var redirect = @Context.Request.Query["redirect"].ToString().ToLower();

                                if (redirect == "accountbets")
                                {

                                    <a asp-action="AccountBets"
                                       asp-controller="Bet"
                                       asp-route-id=@Model.AccountID
                                       class="btn btn-secondary">Cancel</a>
                                    <input type="hidden" name="redirect" value="@redirect" />


                                }
                                else
                                {
                                    <a asp-action="Index" asp-controller="Bet" class="btn btn-secondary">Cancel</a>

                                }
                            }

                            
                            <button type="submit" class="btn btn-primary">
                                Save Changes
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}
